{
  "buildCommand": "pip install -r requirements.txt && python -m backend.seed_knowledge_base || true",
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "PYTHONUNBUFFERED": "1"
  },
  "functions": {
    "backend/api/app.py": {
      "memory": 3008,
      "maxDuration": 300,
      "runtime": "python3.12"
    }
  }
}
