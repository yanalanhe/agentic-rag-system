# Gemini API key (required for Planner, Validator, Synthesizer).
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: model for generateContent. Default: gemini-2.0-flash-lite (free tier: 15 RPM, 1000 RPD).
# Use gemini-2.0-flash for higher limits (may require billing). 429 errors trigger automatic retry.
#GEMINI_MODEL=gemini-2.0-flash-lite
